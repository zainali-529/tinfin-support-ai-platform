    "bullmq": "^5.72.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.31.0",
    "express": "^4.19.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.0",
    "openai": "^4.52.0",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
